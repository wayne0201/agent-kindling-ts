# 复制此文件为 .env 并填入真实信息

# ── 模型提供商选择 ──
# 可选值: glm | deepseek
# 控制 Chat 模型使用哪个 Provider
LLM_PROVIDER="glm"

# ── 智谱 GLM ──
ZHIPU_API_KEY="your_zhipu_api_key_here"
ZHIPU_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
ZHIPU_MODEL="glm-4.5-air"

# ── DeepSeek ──
DEEPSEEK_API_KEY="your_deepseek_api_key_here"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-flash"

# ── Embedding 配置（Stage 4 RAG 需要）·──
# Embedding 与 Chat 独立配置，可以使用不同的 Provider。
# 例如：Chat 用 DeepSeek + Embedding 用智谱 GLM。
#
# ⚠️  DeepSeek 官方 API 不提供 Embedding 服务，不能用 DeepSeek 作为 Embedding Provider。
#
# 推荐方案（任选其一）：
#   A) 智谱 GLM embedding-3（2048 维，本项目默认推荐）
#      EMBEDDING_API_KEY="你的智谱 API Key"（可与上面 ZHIPU_API_KEY 相同）
#      EMBEDDING_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
#      EMBEDDING_MODEL="embedding-3"
#
#   B) SiliconFlow bge-m3（免费，OpenAI 兼容接口）
#      EMBEDDING_API_KEY="你的 SiliconFlow API Key"
#      EMBEDDING_BASE_URL="https://api.siliconflow.cn/v1"
#      EMBEDDING_MODEL="BAAI/bge-m3"
#
#   C) 任何 OpenAI 兼容的 Embedding 服务均可
#
EMBEDDING_API_KEY="your_embedding_api_key_here"
EMBEDDING_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
EMBEDDING_MODEL="embedding-3"
